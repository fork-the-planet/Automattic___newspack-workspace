SITE_URL="https://e2e.local"
ADMIN_USER="admin"
ADMIN_PASSWORD="password"

# Local Docker env only: the container to `docker exec` into for provisioning.
# Derived from the SITE_URL host when unset (e.g. e2e-release.test ->
# newspack_env_e2e_release), so usually you don't need to set this.
# E2E_CONTAINER="newspack_env_e2e_release"

# Remote (CI) provisioning over SSH. Required when SITE_URL is not a local host.
# E2E_SSH_HOST="ssh.atomicsites.net"
# E2E_SSH_USER=""
# E2E_SSH_USER_PASS=""
# E2E_REMOTE_WP_PATH="htdocs"

# Stripe test-mode keys (enables the WooCommerce Stripe gateway during setup).
# STRIPE_PUB_KEY=""
# STRIPE_SECRET_KEY=""
