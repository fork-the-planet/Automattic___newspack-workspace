{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "newspack/overlay-menu-panel",
	"title": "Menu Panel",
	"category": "newspack",
	"description": "The panel that appears when the Overlay Button is triggered. Accepts any blocks as content, making it suitable for navigation menus, search forms, or any custom layout.",
	"textdomain": "newspack-plugin",
	"parent": [
		"newspack/overlay-menu"
	],
	"usesContext": [
		"newspack-overlay-menu/instanceId"
	],
	"attributes": {
		"slideDirection": {
			"type": "string",
			"default": "left"
		},
		"overlayColor": {
			"type": "string",
			"default": ""
		},
		"panelBackgroundColor": {
			"type": "string",
			"default": ""
		},
		"panelTextColor": {
			"type": "string",
			"default": ""
		}
	},
	"supports": {
		"html": false
	},
	"editorStyle": "file:../../../../dist/blocks.css",
	"style": "file:../../../../dist/blocks.css"
}
