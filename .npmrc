# WordPress plugins import packages without declaring them as direct deps --
# they're provided by WordPress at runtime or come transitively through
# @wordpress/scripts / newspack-scripts / newspack-components.
#
# pnpm's strict layout would block these undeclared imports. We hoist only
# the packages known to be used as phantom deps across the workspace.
#
# To tighten further: declare each import explicitly in the consuming
# plugin's package.json and remove the corresponding line here.

# WordPress core packages (resolved at runtime by wp-dependency-extraction-webpack-plugin)
public-hoist-pattern[]=@wordpress/*

# React ecosystem (provided by WordPress at runtime)
public-hoist-pattern[]=react
public-hoist-pattern[]=react-dom
public-hoist-pattern[]=react-router-dom
public-hoist-pattern[]=prop-types

# Utility libraries used without explicit declaration
public-hoist-pattern[]=lodash
public-hoist-pattern[]=lodash-es
public-hoist-pattern[]=classnames
public-hoist-pattern[]=clsx
public-hoist-pattern[]=moment
public-hoist-pattern[]=jquery
public-hoist-pattern[]=redux
public-hoist-pattern[]=qs
public-hoist-pattern[]=js-cookie

# TypeScript types (needed at build time, not shipped)
public-hoist-pattern[]=@types/*

# ESLint plugins must resolve to a single copy or ESLint errors with
# "couldn't determine plugin uniquely". Hoist to guarantee dedup.
public-hoist-pattern[]=eslint-plugin-*
public-hoist-pattern[]=@typescript-eslint/*
public-hoist-pattern[]=eslint-config-*
public-hoist-pattern[]=eslint

# Peer dep resolution
legacy-peer-deps=true
auto-install-peers=true
strict-peer-dependencies=false
dedupe-peer-dependents=true
